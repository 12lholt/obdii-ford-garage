# Copy to .env (which is gitignored) and fill in. NEVER commit real values.

# Overrides the dongle address in any vehicle profile. Keeps the real address
# out of this public repo.
OBD_CONNECTION_URL=socket://192.168.0.10:35000

# Azure Blob target for `garage upload`. Auth is via Entra ID (run `az login`)
# -- there is intentionally NO SAS token or account key here.
AZURE_STORAGE_ACCOUNT_URL=https://<youraccount>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=obd-snapshots
